# Default: normalize text files and keep LF in the repository.
* text=auto

# Source and build files
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hh text eol=lf
*.hpp text eol=lf
*.inl text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Project/config/docs
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.qrc text eol=lf
*.qss text eol=lf
*.ui text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.editorconfig text eol=lf

# Scripts
*.sh text eol=lf
*.py text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.ttf binary
*.onnx binary
*.dll binary
*.exe binary
*.db binary
